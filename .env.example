# ─── Webhook Security ────────────────────────────────────────────────────────────
# Secret used to verify incoming webhook signatures (HMAC-SHA256).
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# ─── Airtable (client's account) ─────────────────────────────────────────────────
# Personal access token from airtable.com/create/tokens
# Required scopes: data.records:read, data.records:write
AIRTABLE_API_KEY=

# Base ID — visible in the Airtable URL: airtable.com/appXXXXXXXXXX/...
AIRTABLE_BASE_ID=

# Table name — must match exactly (default: Leads)
AIRTABLE_TABLE_NAME=Leads

# ─── Resend (client's account) ───────────────────────────────────────────────────
# API key from resend.com/api-keys
RESEND_API_KEY=

# Audience ID from resend.com/audiences — adding a contact here triggers the drip
RESEND_AUDIENCE_ID=

# Verified sending email address (e.g. hello@clientbusiness.com.au)
RESEND_FROM_EMAIL=

# Display name shown to recipients (e.g. Jane from Sparkle Cleaning)
RESEND_FROM_NAME=

# ─── Twilio SMS — Optional ───────────────────────────────────────────────────────
# Set TWILIO_ENABLED=true to activate SMS. Leave false to skip entirely.
TWILIO_ENABLED=false

# Twilio Account SID — from console.twilio.com (only required if TWILIO_ENABLED=true)
TWILIO_ACCOUNT_SID=

# Twilio Auth Token — from console.twilio.com (only required if TWILIO_ENABLED=true)
TWILIO_AUTH_TOKEN=

# Twilio phone number to send from (e.g. +61412345678) (only required if TWILIO_ENABLED=true)
TWILIO_FROM_NUMBER=

# ─── Telegram (instant client notification) ──────────────────────────────────────
# Bot token — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID — get from @userinfobot on Telegram
TELEGRAM_CHAT_ID=
